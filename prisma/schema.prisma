generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  JOUEUR
  ADMIN
}

enum StatutSalle {
  ATTENTE
  EN_JEU
  TERMINEE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  nom           String
  role          Role           @default(JOUEUR)
  createdAt     DateTime       @default(now())
  scores        Score[]
  salleJoueurs  SalleJoueur[]
}

model Niveau {
  id          Int        @id @default(autoincrement())
  numero      Int        @unique
  titre       String
  description String?
  vitesse     Int        @default(500)
  questions   Question[]
  scores      Score[]
  salles      Salle[]
}

model Question {
  id           Int      @id @default(autoincrement())
  texte        String
  choix        String[]
  bonneReponse Int
  explication  String?
  niveau       Niveau   @relation(fields: [niveauId], references: [id])
  niveauId     Int
}

model Score {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  niveau      Niveau   @relation(fields: [niveauId], references: [id])
  niveauId    Int
  score       Int
  blocsPlaces Int
  reussi      Boolean
  createdAt   DateTime @default(now())
}

model Salle {
  id        String        @id @default(cuid())
  code      String        @unique
  niveauId  Int
  niveau    Niveau        @relation(fields: [niveauId], references: [id])
  hostId    String
  statut    StatutSalle   @default(ATTENTE)
  joueurs   SalleJoueur[]
  createdAt DateTime      @default(now())
}

model SalleJoueur {
  id       String  @id @default(cuid())
  salleId  String
  salle    Salle   @relation(fields: [salleId], references: [id])
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  score    Int     @default(0)
  bloque   Boolean @default(false)
}
